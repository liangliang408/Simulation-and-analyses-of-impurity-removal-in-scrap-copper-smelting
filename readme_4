import matplotlib.pyplot as plt
import numpy as np
from sklearn.metrics import mean_squared_error

def plot_prediction_comparison(y_true, y_pred, dataset_type='train', max_samples=500):
     # 设置中文字体
    plt.rcParams['font.sans-serif'] = ['SimHei']  # 设置字体为 SimHei（黑体）
    plt.rcParams['axes.unicode_minus'] = False  # 解决负号显示问题
    plt.rcParams['font.family']=['SimHei']
    plt.rcParams['font.serif'] = ['SimHei']
    """
    绘制训练集或测试集的预测结果对比图。

    参数:
    y_true: 真实值 (numpy 数组或列表)
    y_pred: 预测值 (numpy 数组或列表)
    dataset_type: 数据集类型 ('train' 或 'test')，用于标题和标签
    max_samples: 最大样本数量，如果样本数量超过此值，只绘制前 max_samples 个样本
    """

    if len(y_true) > max_samples:
        y_true = y_true[:max_samples]
        y_pred = y_pred[:max_samples]
        print(f"样本数量超过 {max_samples}，只绘制前 {max_samples} 个样本。")


    rmse = np.sqrt(mean_squared_error(y_true, y_pred))


    plt.figure(figsize=(8, 6))


    plt.plot(range(1, len(y_true) + 1), y_true, 'r-*', label='真实值')
    plt.plot(range(1, len(y_true) + 1), y_pred, 'b-o', label='预测值')
    plt.xlabel('样本索引')
    plt.ylabel('预测结果')
    plt.title(f"{dataset_type.capitalize()}集预测结果对比\nRMSE={rmse:.4f}")
    plt.xlim([1, len(y_true)])
    plt.legend()
    plt.grid()


    plt.tight_layout()
    # plt.savefig(path+'\ 4.png',dpi=300)
    plt.show()

