def draw_pie_3d(ax, ratios, colors, height=0.05): 
    start_angle = 0
    radius =1000
    
    ax.xaxis.pane.fill = False
    ax.yaxis.pane.fill = False
    ax.zaxis.pane.fill = False
    

    
    for i, ratio in enumerate(ratios):

        angle = ratio * 2 * np.pi / 100
        end_angle = start_angle + angle
        

        r = np.linspace(0, radius, 1000)  
        theta = np.linspace(start_angle, end_angle, 1000)  


        mid_angle = (start_angle + end_angle) / 2
        

        r_grid, theta_grid = np.meshgrid(r, theta)

        x = r_grid * np.cos(theta_grid)
        y = r_grid * np.sin(theta_grid)

        z = np.zeros_like(x)
        ax.plot_surface(x, y, z, color=colors[i], alpha=0.8)
        

        z = np.ones_like(x) * height
        ax.plot_surface(x, y, z, color=colors[i], alpha=0.8)

        r_edge = np.array([radius])
        theta_edge = np.linspace(start_angle, end_angle, 20)
        x_edge = r_edge * np.cos(theta_edge)
        y_edge = r_edge * np.sin(theta_edge)
        z_edge = np.linspace(0, height, 20)
        
        x_edge_grid, z_edge_grid = np.meshgrid(x_edge, z_edge)
        y_edge_grid, _ = np.meshgrid(y_edge, z_edge)
        
        ax.plot_surface(x_edge_grid, y_edge_grid, z_edge_grid, color=colors[i], alpha=0.8)
        
        start_angle = end_angle
 
        label_radius = radius * 0.7
        x_label = label_radius * np.cos(mid_angle)
        y_label = label_radius * np.sin(mid_angle)
       
        ax.text(x_label, y_label, height, 
                f'{ratio:.1f}%', 
                horizontalalignment='center',
                verticalalignment='center',
                fontsize=7, 
                fontweight='bold',
                color='black',  
                alpha=1.0,
                zorder=100)  
        




