import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
from matplotlib import colors as mcolors
from matplotlib.cm import ScalarMappable
from scipy.stats import pearsonr

def calculate_correlations(X, y):
    """
     Pearson 。

    para:
    X -- (n_samples, n_features)
    y --  (n_samples,)

    return:
    correlations --  (n_features,)
    """
    correlations = []
    for i in range(X.shape[1]):  
        corr, _ = pearsonr(X[:, i], y)  
        correlations.append(corr)
    return np.array(correlations)

def plot_shap_feature_importance(features, shap_values, X, y, top_n=10):
    """
    SHAP。

   para:
    features -- 
    shap_values -- 
    X --  (n_samples, n_features)
    y --  (n_samples,)
    top_n -- 
    """
   
    avg_shap_values = np.mean(np.abs(shap_values), axis=0)
    
   
    sorted_idx = np.argsort(avg_shap_values)[::-1]  
    
  
    top_features = np.array(features)[sorted_idx[:top_n]][::-1]
    top_shap_values = avg_shap_values[sorted_idx[:top_n]][::-1]
    
   
    correlations = calculate_correlations(X, y)
    top_correlations = correlations[sorted_idx[:top_n]][::-1]
    
   
    total_shap_value = np.sum(top_shap_values)
    
    
    percentage_values = (top_shap_values / total_shap_value) * 100
    
    
    fig, ax = plt.subplots(figsize=(10, 6))
    
    
    norm = mcolors.Normalize(vmin=-1, vmax=1)
    cmap = plt.get_cmap('viridis')
    sm = ScalarMappable(cmap=cmap, norm=norm)
    sm.set_array([])  
    

    colors = [cmap(norm(cor)) for cor in top_correlations]
    bars = ax.barh(top_features, top_shap_values, color=colors, edgecolor="none") 
    
  
    for i, bar in enumerate(bars):
     
        text_color = 'white' if np.mean(colors[i][:3]) < 0.5 else 'black'
 
        ax.text(bar.get_width() / 2, bar.get_y() + bar.get_height() / 2,
                f'r = {top_correlations[i]:.3f}\n{percentage_values[i]:.2f}%',
                ha='center', va='center', fontsize=10, color=text_color)
    

    ax.set_xlabel('The average value of absolute SHAP value', fontsize=12)
    ax.set_ylabel('Features', fontsize=12)
    ax.set_title('SHAP Feature Importance (Descending Order)', fontsize=14)
    

    for spine in ['top', 'right']:
       ax.spines[spine].set_visible(False)
    

    x_max = np.max(top_shap_values) * 1.2
    ax.set_xlim(0, x_max)
    

    cbar_ax = fig.add_axes([0.91, 0.1, 0.02, 0.8]) 
    cbar = fig.colorbar(sm, cax=cbar_ax)
    cbar.set_label('Positive/Negative correlation level')
    

    plt.tight_layout()
    plt.show()



